<Page x:Class="USBGuard.UI.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F0F0">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="16">

      <!-- Alert banner -->
      <Border x:Name="AlertBanner" Visibility="Collapsed"
              CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
        <DockPanel>
          <Ellipse x:Name="AlertDot" Width="16" Height="16"
                   Fill="#E24B4A" VerticalAlignment="Center"
                   Margin="0,0,10,0"/>
          <Button DockPanel.Dock="Right" Content="Dismiss"
                  Style="{StaticResource GhostBtn}"
                  FontSize="11" Padding="8,4"
                  Click="DismissAlert_Click" Margin="8,0,0,0"/>
          <TextBlock x:Name="AlertText" FontSize="12"
                     VerticalAlignment="Center" TextWrapping="Wrap"/>
        </DockPanel>
      </Border>

      <!-- Metric cards -->
      <UniformGrid Columns="4" Margin="0,0,0,12">
        <Border Background="White" CornerRadius="8" Padding="14"
                BorderBrush="#CCCCCC" BorderThickness="0.5" Margin="0,0,10,0">
          <StackPanel>
            <TextBlock Text="Devices monitored" Foreground="#666"
                       FontSize="11" Margin="0,0,0,5"/>
            <TextBlock x:Name="MetricMonitored" Text="0"
                       FontSize="24" FontWeight="SemiBold" Foreground="#0F6E56"/>
          </StackPanel>
        </Border>
        <Border Background="White" CornerRadius="8" Padding="14"
                BorderBrush="#CCCCCC" BorderThickness="0.5" Margin="0,0,10,0">
          <StackPanel>
            <TextBlock Text="Blocked today" Foreground="#666"
                       FontSize="11" Margin="0,0,0,5"/>
            <TextBlock x:Name="MetricBlocked" Text="0"
                       FontSize="24" FontWeight="SemiBold"/>
          </StackPanel>
        </Border>
        <Border Background="White" CornerRadius="8" Padding="14"
                BorderBrush="#CCCCCC" BorderThickness="0.5" Margin="0,0,10,0">
          <StackPanel>
            <TextBlock Text="Whitelisted" Foreground="#666"
                       FontSize="11" Margin="0,0,0,5"/>
            <TextBlock x:Name="MetricWhitelisted" Text="0"
                       FontSize="24" FontWeight="SemiBold" Foreground="#0F6E56"/>
          </StackPanel>
        </Border>
        <Border Background="White" CornerRadius="8" Padding="14"
                BorderBrush="#CCCCCC" BorderThickness="0.5">
          <StackPanel>
            <TextBlock Text="Uptime" Foreground="#666"
                       FontSize="11" Margin="0,0,0,5"/>
            <TextBlock x:Name="MetricUptime" Text="0m"
                       FontSize="24" FontWeight="SemiBold"/>
          </StackPanel>
        </Border>
      </UniformGrid>

      <!-- Two-column row -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Device table -->
        <Border Grid.Column="0" Style="{StaticResource Card}">
          <StackPanel>
            <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,0.5"
                    Padding="14,10">
              <TextBlock Text="Connected devices"
                         FontSize="12" FontWeight="SemiBold"/>
            </Border>
            <ListView x:Name="DeviceList" BorderThickness="0"
                      FontSize="12" MaxHeight="260"
                      Background="White">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Device" Width="140"
                    DisplayMemberBinding="{Binding Name}"/>
                  <GridViewColumn Header="Vendor" Width="75"
                    DisplayMemberBinding="{Binding VendorId}"/>
                  <GridViewColumn Header="Status" Width="80"
                    DisplayMemberBinding="{Binding Status}"/>
                  <GridViewColumn Header="Score" Width="55"
                    DisplayMemberBinding="{Binding Score}"/>
                </GridView>
              </ListView.View>
            </ListView>
          </StackPanel>
        </Border>

        <!-- Pipeline + score panel -->
        <Border Grid.Column="2" Style="{StaticResource Card}">
          <StackPanel>
            <Border BorderBrush="#CCCCCC" BorderThickness="0,0,0,0.5"
                    Padding="14,10">
              <TextBlock Text="Last detection pipeline"
                         FontSize="12" FontWeight="SemiBold"/>
            </Border>
            <Border Padding="14">
              <StackPanel>

              <TextBlock x:Name="Step1" FontSize="11" Margin="0,0,0,6"
                         Text="1  USB device detected"/>
              <TextBlock x:Name="Step2" FontSize="11" Margin="0,0,0,6"
                         Text="2  Whitelist check"/>
              <TextBlock x:Name="Step3" FontSize="11" Margin="0,0,0,6"
                         Text="3  Descriptor screening"/>
              <TextBlock x:Name="Step4" FontSize="11" Margin="0,0,0,6"
                         Text="4  Behavioural sandbox"/>
              <TextBlock x:Name="Step5" FontSize="11" Margin="0,0,0,12"
                         Text="5  ML classification"/>

              <!-- ML score bar -->
              <TextBlock Text="ML score" FontSize="11"
                         Foreground="#666" Margin="0,0,0,4"/>
              <Grid Height="8" Margin="0,0,0,6">
                <Border Background="#EEEEEE" CornerRadius="4"/>
                <Border x:Name="ScoreBar" HorizontalAlignment="Left"
                        Background="#1D9E75" CornerRadius="4" Width="0"/>
              </Grid>
              <TextBlock x:Name="ScoreLabel" FontSize="11"
                         Foreground="#666" Text="Score: —  ·  Threshold: 0.50"/>

              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

      </Grid>
    </StackPanel>
  </ScrollViewer>
</Page>
