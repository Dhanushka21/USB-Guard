<Page x:Class="USBGuard.UI.Pages.WhitelistPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F0F0">

  <Border Padding="16">
    <StackPanel>

    <!-- Controls row -->
    <DockPanel Margin="0,0,0,12">
      <Button DockPanel.Dock="Right" Content="+ Add current device"
              Style="{StaticResource PrimaryBtn}"
              Padding="14,8" Click="AddDevice_Click"/>
      <ComboBox x:Name="TypeFilter" Width="120" Height="32"
                FontSize="12" Margin="0,0,8,0"
                DockPanel.Dock="Right"
                SelectionChanged="TypeFilter_Changed">
        <ComboBoxItem Content="All types" IsSelected="True"/>
        <ComboBoxItem Content="Keyboard"/>
        <ComboBoxItem Content="Mouse"/>
      </ComboBox>
      <TextBox x:Name="SearchBox" Height="32" FontSize="12"
               Padding="10,0" VerticalContentAlignment="Center"
               BorderBrush="#CCCCCC" BorderThickness="0.5"
               TextChanged="SearchBox_Changed"/>
    </DockPanel>

    <!-- Table -->
    <Border Style="{StaticResource Card}">
      <ListView x:Name="WhitelistView" BorderThickness="0"
                FontSize="12" Background="White">
        <ListView.View>
          <GridView>
            <GridViewColumn Header="Device name"   Width="190"
              DisplayMemberBinding="{Binding Name}"/>
            <GridViewColumn Header="Vendor ID"     Width="90"
              DisplayMemberBinding="{Binding VendorId}"/>
            <GridViewColumn Header="Hash (SHA-256)" Width="130"
              DisplayMemberBinding="{Binding Hash}"/>
            <GridViewColumn Header="Date added"    Width="100"
              DisplayMemberBinding="{Binding DateAdded}"/>
            <GridViewColumn Header="Action"        Width="80">
              <GridViewColumn.CellTemplate>
                <DataTemplate>
                  <Button Content="Remove"
                          Style="{StaticResource DangerBtn}"
                          FontSize="10" Padding="8,3"
                          Tag="{Binding Hash}"
                          Click="RemoveDevice_Click"/>
                </DataTemplate>
              </GridViewColumn.CellTemplate>
            </GridViewColumn>
          </GridView>
        </ListView.View>
      </ListView>
    </Border>

    <TextBlock x:Name="Footer" Margin="0,8,0,0"
               FontSize="11" Foreground="#666"
               Text="0 trusted devices  ·  SHA-256 hashed  ·  AES-256 encrypted"/>

  </StackPanel>
  </Border>
</Page>
